# Production Environment Configuration
# Copy this file to .env.production and customize for your production deployment
# .env.production is gitignored and should not be committed

# =============================================================================
# Build Configuration
# =============================================================================

# Enable source maps in production builds
# Set to 'true' to generate source maps (useful for debugging, but larger bundle)
# Default: false
SOURCE_MAP=false

# Application environment
# Used by the app to determine environment-specific behavior
VITE_APP_ENV=production

# =============================================================================
# Feature Flags (optional)
# =============================================================================

# Enable debug logging in production
# Set to 'true' to see console logs (not recommended for production)
# Default: false
# VITE_ENABLE_DEBUG_LOGGING=false

# =============================================================================
# Notes
# =============================================================================

# This is a minimal configuration for static file serving.
# Additional features like error monitoring, analytics, etc. can be added here.

# For HTTPS deployment, ensure your web server is configured with SSL certificates.
# Several features (clipboard API, camera) require HTTPS in production.
